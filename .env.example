# 环境配置
ENV=dev
NODE_ENV=development

# 应用端口
APP_PORT=8118

# API 前缀
API_PREFIX=api/v1

# 数据库配置
DB_HOST=localhost
DB_PORT=3307
DB_USERNAME=root
DB_PASSWORD=<请设置强密码>
DB_DATABASE=together_dev
DB_SYNCHRONIZE=false

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6383
REDIS_PASSWORD=<请设置密码>

# JWT 配置
JWT_SECRET=<请生成随机密钥，至少32字符>
JWT_REFRESH_SECRET=<请生成随机密钥，至少32字符>
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 对象存储配置
RUSTFS_URL=http://localhost:8121
# 或使用 MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=<请设置>
MINIO_SECRET_KEY=<请设置>
MINIO_BUCKET=together

# CORS 配置
ALLOWED_ORIGINS=http://localhost:3008,http://localhost:5073

# 短信服务配置（可选）
SMS_ACCESS_KEY_ID=<阿里云/腾讯云 AccessKey>
SMS_ACCESS_KEY_SECRET=<阿里云/腾讯云 SecretKey>
SMS_SIGN_NAME=<短信签名>
SMS_TEMPLATE_CODE=<短信模板代码>

# 日志配置
LOG_LEVEL=info

# 监控配置（可选）
SENTRY_DSN=<Sentry DSN>
